{
  "name": "playwright-pom-allure-framework",
  "version": "1.0.0",
  "description": "Scalable JavaScript Playwright POM framework with Allure, GitHub Pages publishing, and notifications.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test --config=config/playwright.config.js",
    "test:headed": "cross-env HEADLESS=false playwright test --config=config/playwright.config.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report:post": "node reports/reportManager.js"
  },
  "keywords": [
    "playwright",
    "javascript",
    "pom",
    "allure",
    "github-pages"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.51.1",
    "allure-commandline": "^2.34.0",
    "allure-playwright": "^3.3.2",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "nodemailer": "^6.10.0"
  }
}
